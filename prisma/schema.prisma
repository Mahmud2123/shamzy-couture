generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  phone        String?
  role         Role      @default(CUSTOMER)
  isActive     Boolean   @default(true)
  address      Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders         Order[]
  measurements   Measurement[]
  designRequests DesignRequest[]
  messages       DesignMessage[]
  auditLogs      AuditLog[]
}

enum Role {
  CUSTOMER
  ADMIN
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String
  price       Float
  category    ProductCategory
  stock       Int           @default(0)
  images      String[]
  status      ProductStatus @default(ACTIVE)
  variations  Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orderItems OrderItem[]
}

enum ProductCategory {
  SUITS
  SHIRTS
  TROUSERS
  JACKETS
  ACCESSORIES
  CUSTOM
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  shippingAddress Json?
  notes           String?
  internalNotes   String?
  assignedTo      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  items      OrderItem[]
  statusLogs OrderStatusLog[]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  price       Float
  customNotes String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Measurement {
  id           String      @id @default(cuid())
  userId       String
  name         String      @default("My Measurements")
  productType  ProductType
  unit         MeasureUnit @default(CM)
  measurements Json
  isDefault    Boolean     @default(false)
  measuredDate DateTime    @default(now())
  notes        String?
  isDeleted    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum ProductType {
  SUIT
  SHIRT
  TROUSER
  JACKET
  CUSTOM
}

enum MeasureUnit {
  CM
  INCHES
}

model DesignRequest {
  id          String              @id @default(cuid())
  userId      String
  title       String
  description String
  budget      Float?
  deadline    DateTime?
  status      DesignRequestStatus @default(PENDING)
  adminNotes  String?
  attachments String[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  messages DesignMessage[]
}

enum DesignRequestStatus {
  PENDING
  REVIEWING
  QUOTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model DesignMessage {
  id              String   @id @default(cuid())
  designRequestId String
  userId          String
  content         String
  createdAt       DateTime @default(now())

  designRequest DesignRequest @relation(fields: [designRequestId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entity     String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
